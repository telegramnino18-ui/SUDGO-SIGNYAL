rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "traderpro11@ninzsignal.com" ||
        request.auth.token.email == "telegramnino18@gmail.com"
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'membership']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.membership in ['free', 'premium', 'pending', 'expired'];
    }

    // Rules for users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if user is creating their own profile with 'user' role, or if admin
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      
      // Allow users to update their own profile (except role), or admin to do anything
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    // Rules for signals collection
    match /signals/{signalId} {
      // Allow everyone to read signals
      allow read: if true;
      
      // Allow admins to do anything
      allow create, update, delete: if isAdmin();
    }
  }
}
